# .env.example
# Purpose: Configuration template for setting environment variables.

# Server Configurations
HOST=127.0.0.1
PORT=8000

# MongoDB Setup
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=dashboard_db

# Security & Session JWT Keys
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth2 Settings (Optional)
# Obtain these from Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth-callback
